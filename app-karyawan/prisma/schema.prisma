generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmploymentType {
  PERMANENT
  CONTRACT
}

enum Gender {
  MALE
  FEMALE
}

enum EducationLevel {
  SMA
  D3
  S1
  S2
}

enum GradeRank {
  RANK_1
  RANK_2
  RANK_3
  RANK_4
  RANK_5
  RANK_6
  RANK_7
  RANK_8
  RANK_9
}

enum GuidanceRecordCategory {
  GUIDANCE
  DIRECTION
}

enum DisciplineLetterCategory {
  WARNING_LETTER
  REPRIMAND
}

model WorkLocation {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(255)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]

  @@map("work_locations")
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(255)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]

  @@map("departments")
}

model JobRole {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(255)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]

  @@map("job_roles")
}

model JobLevel {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(255)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]

  @@map("job_levels")
}

model MasterDokPkb {
  id        Int      @id @default(autoincrement())
  article   String   @unique @db.VarChar(255)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  warningLetters WarningLetter[]

  @@map("master_dok_pkb")
}

model Employee {
  id             Int            @id @default(autoincrement())
  employeeNo     String         @unique @db.VarChar(100)
  password       String         @db.VarChar(255)
  fullName       String         @db.VarChar(255)
  employmentType EmploymentType
  siteDiv        String         @default("CLC") @db.VarChar(100)
  departmentId   Int
  birthDate      DateTime       @db.Date
  gender         Gender
  workLocationId Int
  jobRoleId      Int
  jobLevelId     Int
  educationLevel EducationLevel
  grade          GradeRank
  joinDate       DateTime       @db.Date
  phoneNumber    String         @db.VarChar(50)
  email          String?        @db.VarChar(255)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  department     Department     @relation(fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workLocation   WorkLocation   @relation(fields: [workLocationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  jobRole        JobRole        @relation(fields: [jobRoleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  jobLevel       JobLevel       @relation(fields: [jobLevelId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  guidanceRecords         GuidanceRecord[]
  warningLetters          WarningLetter[] @relation("WarningLetterEmployee")
  warningLetterApprovals WarningLetter[] @relation("WarningLetterSuperior")

  @@index([departmentId])
  @@index([workLocationId])
  @@index([jobRoleId])
  @@index([jobLevelId])
  @@map("employees")
}

model GuidanceRecord {
  id                    Int                    @id @default(autoincrement())
  category              GuidanceRecordCategory @default(GUIDANCE)
  employeeId            Int
  meetingNumber         Int
  meetingDate           DateTime               @db.Date
  meetingTime           String                 @db.VarChar(10)
  location              String                 @db.VarChar(255)
  problemFaced          String                 @db.Text
  problemFacedSecondary String?                @db.Text
  problemCause          String                 @db.Text
  problemSolving        String                 @db.Text
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  employee              Employee               @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([employeeId])
  @@map("guidance_records")
}

model WarningLetter {
  category           DisciplineLetterCategory @default(WARNING_LETTER)
  id                 Int      @id @default(autoincrement())
  employeeId         Int
  superiorEmployeeId Int
  masterDokPkbId     Int?
  warningLevel       Int?
  letterNumber       String   @db.VarChar(25)
  letterDate         DateTime @db.Date
  departmentName     String?  @db.VarChar(255)
  jobLevelName       String?  @db.VarChar(255)
  violation          String   @db.Text
  articleLabel       String?  @db.VarChar(255)
  articleContent     String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  employee           Employee     @relation("WarningLetterEmployee", fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  superiorEmployee   Employee     @relation("WarningLetterSuperior", fields: [superiorEmployeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  masterDokPkb       MasterDokPkb? @relation(fields: [masterDokPkbId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([employeeId])
  @@index([superiorEmployeeId])
  @@index([masterDokPkbId])
  @@map("warning_letters")
}
