generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmploymentType {
  PERMANENT
  CONTRACT
}

enum Gender {
  MALE
  FEMALE
}

enum EducationLevel {
  SMA
  D3
  S1
  S2
}

enum GradeRank {
  RANK_1
  RANK_2
  RANK_3
  RANK_4
  RANK_5
  RANK_6
  RANK_7
  RANK_8
  RANK_9
}

enum GuidanceRecordCategory {
  GUIDANCE
  DIRECTION
}

enum DisciplineLetterCategory {
  WARNING_LETTER
  REPRIMAND
}

enum LeaveRequestStatus {
  SUBMITTED
  IN_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveApprovalStatus {
  WAITING
  PENDING
  APPROVED
  REJECTED
  LOCKED
  CANCELLED
}

enum LeaveStageType {
  FOREMAN_GROUP_SHIFT
  FOREMAN
  GENERAL_FOREMAN
  SECTION_CHIEF
  DY_DEPT_MANAGER
  DEPT_MANAGER
  SITE_DIV_MANAGER
}

enum EmailOutboxStatus {
  PENDING
  SENT
  FAILED
}

model WorkLocation {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(255)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]

  @@map("work_locations")
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(255)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]

  @@map("departments")
}

model JobRole {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(255)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]

  @@map("job_roles")
}

model JobLevel {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(255)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]

  @@map("job_levels")
}

model MasterUnit {
  id               Int                        @id @default(autoincrement())
  unitName         String                     @db.VarChar(255)
  unitType         String                     @db.VarChar(100)
  capacity         String                     @db.VarChar(255)
  unitSerialNumber String                     @db.VarChar(255)
  detailLainnya    String                     @db.VarChar(255)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  certifications   UnitLicenseCertification[]

  @@map("master_units")
}

model MasterVendor {
  id             Int                        @id @default(autoincrement())
  vendorName     String                     @db.VarChar(255)
  vendorType     String                     @db.VarChar(100)
  address        String                     @db.VarChar(255)
  picName        String                     @db.VarChar(255)
  phoneNumber    String                     @db.VarChar(100)
  email          String                     @db.VarChar(255)
  detailLainnya  String                     @db.VarChar(255)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  certifications UnitLicenseCertification[]

  @@map("master_vendors")
}

model MasterDokPkb {
  id             Int             @id @default(autoincrement())
  article        String          @unique @db.VarChar(255)
  content        String          @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  warningLetters WarningLetter[]

  @@map("master_dok_pkb")
}

model MasterDokKaryawan {
  id                    Int                            @id @default(autoincrement())
  documentName          String                         @db.VarChar(255)
  documentType          String                         @db.VarChar(100)
  issuer                String                         @db.VarChar(255)
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  licenseCertifications EmployeeLicenseCertification[]

  @@map("master_dok_karyawan")
}

model MasterCutiKaryawan {
  id              Int                   @id @default(autoincrement())
  leaveType       String                @db.VarChar(255)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  records         EmployeeLeave[]
  revisionRecords EmployeeLeaveRevision[]
  databaseRecords EmployeeLeaveDatabase[]

  @@map("master_cuti_karyawan")
}

model MasterGroupShift {
  id             Int                 @id @default(autoincrement())
  groupShiftName String              @db.VarChar(255)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  employees      Employee[]
  foremen        GroupShiftForeman[]

  @@map("master_group_shifts")
}

model GroupShiftForeman {
  id                 Int              @id @default(autoincrement())
  masterGroupShiftId Int
  employeeId         Int
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  masterGroupShift   MasterGroupShift @relation(fields: [masterGroupShiftId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employee           Employee         @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([masterGroupShiftId, employeeId])
  @@index([masterGroupShiftId])
  @@index([employeeId])
  @@map("group_shift_foremen")
}

model Employee {
  id                     Int                            @id @default(autoincrement())
  employeeNo             String                         @unique @db.VarChar(100)
  password               String                         @db.VarChar(255)
  fullName               String                         @db.VarChar(255)
  employmentType         EmploymentType
  siteDiv                String                         @default("CLC") @db.VarChar(100)
  departmentId           Int
  groupShiftId           Int?
  birthDate              DateTime                       @db.Date
  gender                 Gender
  workLocationId         Int
  jobRoleId              Int
  jobLevelId             Int
  educationLevel         EducationLevel
  grade                  GradeRank
  joinDate               DateTime                       @db.Date
  phoneNumber            String                         @db.VarChar(50)
  email                  String?                        @db.VarChar(255)
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  department             Department                     @relation(fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  groupShift             MasterGroupShift?              @relation(fields: [groupShiftId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workLocation           WorkLocation                   @relation(fields: [workLocationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  jobRole                JobRole                        @relation(fields: [jobRoleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  jobLevel               JobLevel                       @relation(fields: [jobLevelId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  guidanceRecords        GuidanceRecord[]
  warningLetters         WarningLetter[]                @relation("WarningLetterEmployee")
  warningLetterApprovals WarningLetter[]                @relation("WarningLetterSuperior")
  adminAccounts          MasterAdmin[]
  licenseCertifications  EmployeeLicenseCertification[]
  leaveRecords           EmployeeLeave[]                @relation("EmployeeLeaveRequester")
  leaveReplacementRequests EmployeeLeave[]             @relation("EmployeeLeaveReplacement")
  leaveDatabaseRecords   EmployeeLeaveDatabase[]
  leaveApprovals         EmployeeLeaveApproval[]        @relation("EmployeeLeaveApprover")
  leaveBalanceSeeds      EmployeeLeaveBalanceSeed[]
  leaveRevisionReplacements EmployeeLeaveRevision[]     @relation("EmployeeLeaveRevisionReplacement")
  groupShiftAssignments  GroupShiftForeman[]

  @@index([departmentId])
  @@index([groupShiftId])
  @@index([workLocationId])
  @@index([jobRoleId])
  @@index([jobLevelId])
  @@map("employees")
}

model EmployeeLeave {
  id                   Int                   @id @default(autoincrement())
  requestNumber        String                @unique @db.VarChar(50)
  employeeId           Int
  masterCutiKaryawanId Int
  leaveYear            Int
  revisionNo           Int                   @default(1)
  status               LeaveRequestStatus    @default(SUBMITTED)
  leaveDays            Int
  periodStart          DateTime              @db.Date
  periodEnd            DateTime              @db.Date
  balanceBefore        Int
  remainingLeave       Int
  currentStageOrder    Int?
  notes                String?               @db.Text
  leaveAddress         String?               @db.Text
  leaveReason          String?               @db.Text
  replacementEmployeeId Int?
  rejectionNote        String?               @db.Text
  submittedAt          DateTime              @default(now())
  approvedAt           DateTime?
  rejectedAt           DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  employee             Employee              @relation("EmployeeLeaveRequester", fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  replacementEmployee  Employee?             @relation("EmployeeLeaveReplacement", fields: [replacementEmployeeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  masterCutiKaryawan   MasterCutiKaryawan    @relation(fields: [masterCutiKaryawanId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  revisions            EmployeeLeaveRevision[]
  approvals            EmployeeLeaveApproval[]
  emailOutbox          EmailOutbox[]

  @@index([employeeId])
  @@index([replacementEmployeeId])
  @@index([masterCutiKaryawanId])
  @@index([status])
  @@index([leaveYear])
  @@map("employee_leaves")
}

model EmployeeLeaveDatabase {
  id                   Int               @id @default(autoincrement())
  employeeId           Int
  masterCutiKaryawanId Int
  leaveDays            Int
  periodStart          DateTime          @db.Date
  periodEnd            DateTime          @db.Date
  remainingLeave       Int
  notes                String?           @db.Text
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  employee             Employee          @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  masterCutiKaryawan   MasterCutiKaryawan @relation(fields: [masterCutiKaryawanId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([employeeId])
  @@index([masterCutiKaryawanId])
  @@index([periodStart])
  @@map("employee_leave_database")
}

model EmployeeLeaveRevision {
  id                   Int                @id @default(autoincrement())
  employeeLeaveId      Int
  revisionNo           Int
  masterCutiKaryawanId Int
  replacementEmployeeId Int?
  status               LeaveRequestStatus
  leaveDays            Int
  periodStart          DateTime           @db.Date
  periodEnd            DateTime           @db.Date
  balanceBefore        Int
  remainingLeave       Int
  notes                String?            @db.Text
  leaveAddress         String?            @db.Text
  leaveReason          String?            @db.Text
  rejectionNote        String?            @db.Text
  submittedAt          DateTime           @default(now())
  approvedAt           DateTime?
  rejectedAt           DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  employeeLeave        EmployeeLeave      @relation(fields: [employeeLeaveId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  masterCutiKaryawan   MasterCutiKaryawan @relation(fields: [masterCutiKaryawanId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  replacementEmployee  Employee?          @relation("EmployeeLeaveRevisionReplacement", fields: [replacementEmployeeId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([employeeLeaveId, revisionNo])
  @@index([employeeLeaveId])
  @@index([masterCutiKaryawanId])
  @@index([replacementEmployeeId])
  @@map("employee_leave_revisions")
}

model EmployeeLeaveApproval {
  id               Int                @id @default(autoincrement())
  employeeLeaveId  Int
  revisionNo       Int
  stageOrder       Int
  stageType        LeaveStageType
  approverEmployeeId Int
  status           LeaveApprovalStatus @default(WAITING)
  actionNote       String?             @db.Text
  actedAt          DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  employeeLeave    EmployeeLeave       @relation(fields: [employeeLeaveId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  approverEmployee Employee            @relation("EmployeeLeaveApprover", fields: [approverEmployeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  emailOutbox      EmailOutbox[]

  @@unique([employeeLeaveId, revisionNo, stageOrder, approverEmployeeId])
  @@index([employeeLeaveId])
  @@index([approverEmployeeId])
  @@index([status])
  @@map("employee_leave_approvals")
}

model EmployeeLeaveBalanceSeed {
  id             Int      @id @default(autoincrement())
  employeeId     Int
  year           Int
  openingBalance Int
  currentBalance Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([employeeId, year])
  @@index([employeeId])
  @@index([year])
  @@map("employee_leave_balance_seeds")
}

model EmailOutbox {
  id                    Int               @id @default(autoincrement())
  employeeLeaveId       Int?
  employeeLeaveApprovalId Int?
  revisionNo            Int?
  recipientEmail        String            @db.VarChar(255)
  recipientName         String?           @db.VarChar(255)
  subject               String            @db.VarChar(255)
  htmlBody              String?           @db.Text
  textBody              String?           @db.Text
  status                EmailOutboxStatus @default(PENDING)
  sentAt                DateTime?
  errorMessage          String?           @db.Text
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  employeeLeave         EmployeeLeave?    @relation(fields: [employeeLeaveId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  employeeLeaveApproval EmployeeLeaveApproval? @relation(fields: [employeeLeaveApprovalId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([employeeLeaveId])
  @@index([employeeLeaveApprovalId])
  @@index([status])
  @@map("email_outbox")
}

model MasterAdmin {
  id         Int      @id @default(autoincrement())
  employeeId Int      @unique
  password   String   @db.VarChar(255)
  role       String   @db.VarChar(20)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([employeeId])
  @@map("master_admins")
}

model GuidanceRecord {
  id                    Int                    @id @default(autoincrement())
  category              GuidanceRecordCategory @default(GUIDANCE)
  employeeId            Int
  meetingNumber         Int
  meetingDate           DateTime               @db.Date
  meetingTime           String                 @db.VarChar(10)
  location              String                 @db.VarChar(255)
  problemFaced          String                 @db.Text
  problemFacedSecondary String?                @db.Text
  problemCause          String                 @db.Text
  problemSolving        String                 @db.Text
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  employee              Employee               @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([employeeId])
  @@map("guidance_records")
}

model WarningLetter {
  category           DisciplineLetterCategory @default(WARNING_LETTER)
  id                 Int                      @id @default(autoincrement())
  employeeId         Int
  superiorEmployeeId Int
  masterDokPkbId     Int?
  warningLevel       Int?
  letterNumber       String                   @db.VarChar(25)
  letterDate         DateTime                 @db.Date
  departmentName     String?                  @db.VarChar(255)
  jobLevelName       String?                  @db.VarChar(255)
  violation          String                   @db.Text
  articleLabel       String?                  @db.VarChar(255)
  articleContent     String?                  @db.Text
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  employee           Employee                 @relation("WarningLetterEmployee", fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  superiorEmployee   Employee                 @relation("WarningLetterSuperior", fields: [superiorEmployeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  masterDokPkb       MasterDokPkb?            @relation(fields: [masterDokPkbId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([employeeId])
  @@index([superiorEmployeeId])
  @@index([masterDokPkbId])
  @@map("warning_letters")
}

model EmployeeLicenseCertification {
  id                  Int               @id @default(autoincrement())
  employeeId          Int
  masterDokKaryawanId Int
  type                String            @db.VarChar(255)
  documentNumber      String            @db.VarChar(255)
  issuerSnapshot      String            @db.VarChar(255)
  expiryDate          DateTime          @db.Date
  notes               String?           @db.Text
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  employee            Employee          @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  masterDokKaryawan   MasterDokKaryawan @relation(fields: [masterDokKaryawanId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([employeeId])
  @@index([masterDokKaryawanId])
  @@map("employee_license_certifications")
}

model UnitLicenseCertification {
  id             Int          @id @default(autoincrement())
  masterUnitId   Int
  assetNo        String       @db.VarChar(255)
  documentNumber String       @db.VarChar(255)
  issuedBy       String       @db.VarChar(255)
  vendorId       Int
  expiryDate     DateTime     @db.Date
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  masterUnit     MasterUnit   @relation(fields: [masterUnitId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  vendor         MasterVendor @relation(fields: [vendorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([masterUnitId])
  @@index([vendorId])
  @@map("unit_license_certifications")
}
